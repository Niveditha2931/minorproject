# AI Service Environment Configuration

# Google Cloud Platform
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GEMINI_API_KEY=your-gemini-api-key
GCS_BUCKET=your-bucket-name

# OpenWeatherMap API (for weather data)
# Get your free API key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-api-key

# NASA FIRMS API (for fire data)
# Get your free API key at: https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_API_KEY=your-nasa-firms-api-key

# PostgreSQL Database
# For storing scheduled data fetches
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crisis_response

# Vertex AI Model Endpoints (optional, for production)
# DAMAGE_MODEL_ENDPOINT=projects/.../locations/.../endpoints/...
# RESOURCE_MODEL_ENDPOINT=projects/.../locations/.../endpoints/...
